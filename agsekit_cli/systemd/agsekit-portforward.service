[Unit]
Description=agsekit portforward (user service)
After=network-online.target

[Service]
Type=simple
EnvironmentFile=%h/.config/agsekit/systemd.env
ExecStart=/bin/bash -lc 'exec "$AGSEKIT_BIN" portforward --config "$AGSEKIT_CONFIG"'
Restart=always
RestartSec=2

[Install]
WantedBy=default.target
